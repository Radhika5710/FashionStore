<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
         xmlns="https://jakarta.ee/xml/ns/jakartaee" 
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd" 
         version="5.0">
         
  <display-name>FashionStore</display-name>

  <!-- Filter Mappings - Order matters! -->
  
  <!-- FILTER CHAIN ORDER REQUIREMENTS:
       ================================
       The order of filters is CRITICAL for proper security and logging:
       
       1. RequestLoggingFilter (MUST BE FIRST)
          - Adds request ID to MDC for all subsequent logging
          - Enables request tracing across all security filters
          - Logs request duration and status
       
       2. CORSFilter (MUST BE SECOND)
          - Handles CORS preflight requests (OPTIONS)
          - Sets CORS headers for cross-origin requests
          - Returns early for OPTIONS requests
       
       3. SecurityHardeningFilter (MUST BE THIRD)
          - Rate limiting and brute-force protection
          - Attack pattern detection
          - Security headers (CSP, X-Frame-Options, etc.)
          - Session cookie configuration
       
       4. DemoHardeningFilter (MUST BE FOURTH)
          - Disables non-essential routes in demo mode
          - Protects sensitive endpoints
       
       5. JWTAuthenticationFilter (MUST BE FIFTH)
          - JWT validation for /api/admin/* endpoints
          - Skips JSP routes (session auth)
          - Skips static assets
          - Returns JSON errors for unauthorized requests
       
       6. FileUploadSecurityFilter (APPLIED TO UPLOAD ENDPOINTS ONLY)
          - Validates file uploads
          - Prevents malicious file uploads
       
       DO NOT CHANGE THIS ORDER WITHOUT SECURITY REVIEW
       =============================================== -->
  
  <!-- 1. Request Logging (adds request ID to MDC for all subsequent logging) -->
  <filter>
    <filter-name>RequestLoggingFilter</filter-name>
    <filter-class>com.fashionstore.filter.RequestLoggingFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>RequestLoggingFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <!-- 2. CORS (handle cross-origin requests) -->
  <filter>
    <filter-name>CORSFilter</filter-name>
    <filter-class>com.fashionstore.filter.CORSFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>CORSFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <!-- 3. Security Hardening (rate limiting, CSP headers) -->
  <!-- Mapped to /* but skips FORWARD/INCLUDE/ERROR dispatches internally -->
  <filter>
    <filter-name>SecurityHardeningFilter</filter-name>
    <filter-class>com.fashionstore.filter.SecurityHardeningFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>SecurityHardeningFilter</filter-name>
    <url-pattern>/*</url-pattern>
    <dispatcher>REQUEST</dispatcher>
  </filter-mapping>

  <!-- 3.5. Demo Hardening (disables non-essential routes in demo mode) -->
  <filter>
    <filter-name>DemoHardeningFilter</filter-name>
    <filter-class>com.fashionstore.filter.DemoHardeningFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>DemoHardeningFilter</filter-name>
    <url-pattern>/*</url-pattern>
    <dispatcher>REQUEST</dispatcher>
  </filter-mapping>

  <!-- 4. JWT Authentication Filter — ONLY protects /api/admin/* -->
  <!-- Mapped narrowly so it never runs on storefront or static asset requests -->
  <filter>
    <filter-name>JWTAuthenticationFilter</filter-name>
    <filter-class>com.fashionstore.filter.JWTAuthenticationFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>JWTAuthenticationFilter</filter-name>
    <url-pattern>/api/admin/*</url-pattern>
    <dispatcher>REQUEST</dispatcher>
  </filter-mapping>

  <!-- 4. File Upload Security (apply to upload endpoints only) -->
  <filter>
    <filter-name>FileUploadSecurityFilter</filter-name>
    <filter-class>com.fashionstore.security.FileUploadSecurityFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>FileUploadSecurityFilter</filter-name>
    <url-pattern>/upload</url-pattern>
    <url-pattern>/api/upload</url-pattern>
    <url-pattern>/admin/upload</url-pattern>
  </filter-mapping>

  <!-- Error Pages Configuration -->
  <error-page>
    <error-code>404</error-code>
    <location>/WEB-INF/views/errors/404.jsp</location>
  </error-page>
  
  <error-page>
    <error-code>500</error-code>
    <location>/WEB-INF/views/errors/500.jsp</location>
  </error-page>
  
  <error-page>
    <error-code>401</error-code>
    <location>/WEB-INF/views/errors/401.jsp</location>
  </error-page>
  
  <error-page>
    <exception-type>java.lang.Throwable</exception-type>
    <location>/WEB-INF/views/errors/500.jsp</location>
  </error-page>

  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
    <welcome-file>home</welcome-file>
  </welcome-file-list>

  <!-- Session Configuration -->
  <!-- Cookie security flags are set programmatically based on environment (HTTP vs HTTPS) -->
  <session-config>
    <session-timeout>15</session-timeout>
    <cookie-config>
      <http-only>true</http-only>
      <!-- secure and same-site are set programmatically in SecurityHardeningFilter -->
    </cookie-config>
    <tracking-mode>COOKIE</tracking-mode>
  </session-config>

  <!-- JSP Servlet Configuration for Tomcat 10.x Jasper Compiler -->
  <servlet>
    <servlet-name>jsp</servlet-name>
    <servlet-class>org.apache.jasper.servlet.JspServlet</servlet-class>
    <init-param>
      <param-name>fork</param-name>
      <param-value>false</param-value>
    </init-param>
    <init-param>
      <param-name>xpoweredBy</param-name>
      <param-value>false</param-value>
    </init-param>
    <init-param>
      <param-name>development</param-name>
      <param-value>true</param-value>
    </init-param>
    <init-param>
      <param-name>enablePooling</param-name>
      <param-value>false</param-value>
    </init-param>
    <load-on-startup>3</load-on-startup>
  </servlet>
  <servlet-mapping>
    <servlet-name>jsp</servlet-name>
    <url-pattern>*.jsp</url-pattern>
  </servlet-mapping>

</web-app>
