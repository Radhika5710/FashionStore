# ============================================================
# ENVIRONMENT VARIABLES - FashionStore
# Copy this file to .env and configure for your environment
# DO NOT commit .env file to version control
# ============================================================

# Application Environment
ENVIRONMENT=development
APP_NAME=fashionstore
APP_VERSION=1.0.0

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_NAME=fashionstore
DB_USER=root
DB_PASSWORD=Tarun@1605
MYSQL_ROOT_PASSWORD=Tarun@1605
JWT_SECRET_KEY=generate_a_strong_64_char_secret_here

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Application Configuration
SERVER_PORT=8080
JWT_SECRET_KEY=change_this_jwt_secret_in_production_min_64_chars
FASHIONSTORE_ADMIN_KEY=change_this_admin_key_in_production

# Security Configuration (CRITICAL - SET THESE IN PRODUCTION)
HTTPS_ENABLED=false
SECURE_COOKIES=false
RATE_LIMIT_ENABLED=false
CSRF_ENABLED=false
QA_MODE=true

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Logging Configuration
LOG_LEVEL=DEBUG
LOG_FORMAT=TEXT

# Nginx Configuration
NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_SSL_ENABLED=false

# Docker Configuration
COMPOSE_PROJECT_NAME=fashionstore

# ============================================================
# SECURITY NOTES
# ============================================================
# 1. NEVER commit .env file to version control
# 2. Use strong, unique passwords for all environments
# 3. JWT_SECRET_KEY must be at least 64 characters in production
# 4. Enable HTTPS_ENABLED and SECURE_COOKIES in production
# 5. Enable RATE_LIMIT_ENABLED in production
# 6. Enable DB_SSL in production
# 7. Rotate secrets regularly
